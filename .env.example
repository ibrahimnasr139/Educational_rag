HOST=0.0.0.0
PORT=8000
DEBUG=False
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

DATABASE_URL=sqlite:///./data/app.db
VECTOR_DB_PATH=./data/chroma_db
UPLOAD_PATH=./data/uploads
TEMP_PATH=./data/temp
TRANSCRIPT_PATH=./data/transcripts

GOOGLE_API_KEY=
OPENAI_API_KEY=
HF_TOKEN=
LLM_PROVIDER=openai
ALLOW_GEMINI_FALLBACK=false
GEMINI_MODEL=gemini-2.5-flash
OPENAI_MODEL=gpt-4.1-nano

EMBEDDING_PROVIDER=sentence_transformer
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BATCH_SIZE=32

ENABLE_AUDIO_PROCESSING=true
ENABLE_OCR_PROCESSING=true
KEEP_UPLOADED_FILES=true
SAVE_TRANSCRIPT_FILES=true
SAVE_CHUNKS_TO_POSTGRES=true

TRANSCRIPTION_PROVIDER=local
OPENAI_TRANSCRIPTION_MODEL=whisper-1
WHISPER_MODEL=base
WHISPER_DEVICE=cpu

OCR_PROVIDER=local
OPENAI_OCR_MODEL=gpt-4.1-mini
TESSERACT_PATH=
OCR_LANGUAGES=ara+eng

CHUNK_SIZE=1000
CHUNK_OVERLAP=150
MAX_FILE_SIZE=500
DEFAULT_LANGUAGE=ar
FALLBACK_LANGUAGE=en
SUPPORTED_LANGUAGES=ar,en,fr,es

# Bunny CDN Config
BUNNY_ACCESS_KEY=f4bcd605-1bac-4879-96cbb58907f3-6d4a-44b3

